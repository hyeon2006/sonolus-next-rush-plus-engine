    "compilerOptions": {
        "lib": ["ES2021", "DOM"],
        "target": "ES2021",
        "module": "node16",
        "moduleResolution": "node16",
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
